@using OarabileMarwane_CV.ViewModel

@model FullCvViewModel


@{
    ViewData["Title"] = "Full CV";
}

<div class="main-wrapper">
    <div class="container px-3 px-lg-5">
        <article class="resume-wrapper mx-auto theme-bg-light p-5 mb-5 my-5 shadow-lg">

            <!--//resume-header-->
            <div class="resume-header">
                <div class="row align-items-start">
                    <div class="col-12 col-md-3 col-xl-2 text-center">
                        <img class="resume-profile-image mb-3 mb-md-0 me-md-5  ms-md-0 rounded mx-auto" src="@Model.ContactInfo.avatar" alt="A Handsom Student Developer">
                    </div>
                    <div class="resume-title col-12 col-md-6 col-lg-8 col-xl-9">
                        <h2 class="resume-name mb-0 text-uppercase text-center text-md-start">
                            @Model.ContactInfo.FirstName @Model.ContactInfo.LastName
                        </h2>

                        <div class="row align-items-center">

                            <!-- LEFT SIDE -->
                            <div class="col-12 col-md-7">
                                <div class="resume-tagline mb-3 mb-md-0">
                                    @Model.ContactInfo.Title
                                </div>
                            </div>

                            <!-- RIGHT SIDE -->
                            <div class="col-12 col-md-5 text-md-end">
                                <ul class="list-unstyled mb-0">
                                    <li class="mb-2">
                                        <i class="fas fa-phone-square fa-fw fa-lg me-2"></i>
                                        @Model.ContactInfo.PhoneNumber
                                    </li>
                                    <li class="mb-2">
                                        <i class="fas fa-envelope-square fa-fw fa-lg me-2"></i>
                                        @Model.ContactInfo.Email
                                    </li>
                                    <li class="mb-2">
                                        <i class="fas fa-map-marker-alt fa-fw fa-lg me-2"></i>
                                        @Model.ContactInfo.Location
                                    </li>
                                    <li>
                                        <i class="fa-brands fa-linkedin fa-fw fa-lg me-2"></i>
                                        <a href="@Model.ContactInfo.Linkedin" target="_blank">
                                            LinkedIn
                                        </a>
                                    </li>
                                </ul>
                            </div>

                    </div>

                    

                </div>
            </div>

            <hr />

            <!-- ABOUT -->
            <div class="resume-intro py-3">
                <div class="row align-items-center">
                    <div class="col text-start">
                        <p>@Model.ContactInfo.AboutMe</p>
                    </div>
                </div>
            </div>

            

            <hr />

            <div class="resume-body">
                <div class="row">

                    <!-- MAIN CONTENT -->
                    <div class="resume-main col-12 col-lg-8 col-xl-9 pe-0 pe-lg-5">

                        <!-- EXPERIENCE -->
                        <section class="work-section py-3">
                            <h3 class="text-uppercase resume-section-heading mb-4">
                                Work Experience
                            </h3>

                            @foreach (var job in Model.Experiences)
                            {
                                <div class="item mb-3">
                                    <div class="item-heading row align-items-center mb-2">
                                        <h4 class="item-title col-12 col-md-6 col-lg-8">
                                            @job.JobTitle
                                        </h4>
                                        <div class="item-meta col-12 col-md-6 col-lg-4 text-muted text-md-end">
                                            @job.Company |
                                            @job.StartDate.ToString("yyyy") -
                                            @(job.EndDate.Year == DateTime.Now.Year ? "Present" : job.EndDate.ToString("yyyy"))
                                        </div>
                                    </div>
                                    <div class="item-content">
                                        <p>@job.JobDescription</p>
                                    </div>
                                </div>
                            }
                        </section>

                        <!-- EDUCATION -->
                        <section class="education-section py-3">
                            <h3 class="text-uppercase resume-section-heading mb-4">
                                Education
                            </h3>

                            @foreach (var edu in Model.Educations)
                            {
                                <div class="item mb-3">
                                <div class="item-heading row align-items-center mb-2">
                                    <h4 class="item-title col-12 col-md-6 col-lg-8">
                                        @edu.Degree
                                    </h4>

                                    <div class="item-meta col-12 col-md-6 col-lg-4 text-muted text-md-end">
                                        @edu.InstitutionName |
                                        @edu.StartDate.ToString("yyyy") -
                                        @edu.EndDate.ToString("yyyy")
                                    </div>
                                    </div>
                                    <div>@edu.Descrip</div>
                                </div>
                            }
                        </section>

                        <!-- SKILLS -->
                        <section class="skills-section py-3">
                            <h3 class="text-uppercase resume-section-heading mb-4">
                                Skills
                            </h3>
                            <ul style="list-style-type:disc;">
                                @foreach (var skill in Model.Skills)
                                {
                                    <li class="mb-2">@skill.SkillDescp</li>
                                }
                            </ul>
                        </section>

                    </div>

                    <!-- SIDEBAR -->
                    <aside class="resume-aside col-12 col-lg-4 col-xl-3 px-lg-4 pb-lg-4">

                        <!-- PROJECTS -->
                        <section class="project-section py-3">
                            <h3 class="text-uppercase resume-section-heading mb-4">
                                Projects
                            </h3>

                            @foreach (var project in Model.Projects)
                            {
                                <div class="item mb-3">
                                    <div class="item-heading row align-items-center mb-2">
                                        <h4 class="item-title col-12 col-md-6 col-lg-8">
                                            @project.Name
                                        </h4>
                                    </div>
                                    <div class="item-content">
                                        <p>@project.Description</p>
                                        <a href="@project.GitHubLink" target="_blank" class="theme-link">
                                            View on GitHub
                                        </a>
                                    </div>
                                </div>
                            }
                        </section>

                       

                        

                        <!-- CERTIFICATIONS -->
                        <section class="education-section py-3">
                            <h3 class="text-uppercase resume-section-heading mb-4">
                                Certifications
                            </h3>

                            @foreach (var cert in Model.Certifications)
                            {
                                <div class="item mb-3">
                                    <div class="item-heading row align-items-center mb-2">

                                        <h4 class="item-title col-12 col-md-6 col-lg-8">
                                            @cert.NameOfCert
                                        </h4>
                                        <div class="item-meta col-12 col-md-6 col-lg-4 text-muted text-md-end">
                                            @cert.Organisation
                                        </div>
                                    
                                    </div>
                                    <div class="item-meta text-md-start">
                                            Date of Issued:@cert.IssueDate.ToString("yyyy")
                                    </div>
                                    <div class="item-meta text-md-start">
                                            Date of Expiry:     @cert.ExpiryDate.ToString("yyyy")
                                    </div>
                                </div>
                            }
                        </section>

                    </aside>

                    
                </div>
                
            </div>
            

        </article>

        <footer class="footer text-center py-4">
            <!--/* This template is free as long as you keep the footer attribution link. If you'd like to use the template without the attribution link, you can buy the commercial license via our website: themes.3rdwavemedia.com Thank you for your support. :) */-->
            <small class="copyright text-muted">Designed with <span class="sr-only">love</span><i class="fas fa-heart"></i> by <a class="theme-link" href="http://themes.3rdwavemedia.com" target="_blank">Xiaoying Riley</a> for developers</small>
        </footer>

    </div>
</div>